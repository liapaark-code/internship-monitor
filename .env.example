# ── Twilio SMS ────────────────────────────────────────────────
# Get these from https://console.twilio.com after creating an account.
# Leave blank to run SMS in DRY-RUN mode (the SMS text is logged, not sent).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio phone number that sends the SMS (E.164 format, e.g. +18445551234)
TWILIO_FROM_NUMBER=
# Your phone number that receives the SMS (E.164 format, e.g. +13125551234)
NOTIFY_PHONE_NUMBER=

# ── Discord ───────────────────────────────────────────────────
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# ── Database / paths (defaults are fine) ─────────────────────
DATABASE_PATH=data/internships.db
LOG_DIR=logs

# ── Behavior overrides (optional) ────────────────────────────
# Set to "true" to force dry-run even with Twilio credentials present
DRY_RUN=
